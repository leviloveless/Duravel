+  running: number;
+  nonRunningCardio: number;
+  total: number;
+}
+
+export function weekTimeByCategory(week: { days: { sessions: Session[] }[] }): WeekTimeBreakdown {
+  const out: WeekTimeBreakdown = {
+    metcon: 0,
+    strength: 0,
+    running: 0,
+    nonRunningCardio: 0,
+    total: 0,
+  };
+  for (const day of week.days) {
+    for (const s of day.sessions) {
+      const t = sessionTiming(s).total;
+      if (t <= 0) continue;
+      switch (s.kind) {
+        case "hybrid":
+          out.metcon += t;
+          break;
+        case "lift":
+          out.strength += t;
+          break;
+        case "run":
+          out.running += t;
+          break;
+        case "cardio":
+        case "swim":
+        case "bike":
+        case "brick":
+          out.nonRunningCardio += t;
+          break;
+        default:
+          break;
+      }
+    }
+  }
+  out.total = out.metcon + out.strength + out.running + out.nonRunningCardio;
+  return out;
+}
